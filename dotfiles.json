    ".config/zellij/layouts/htop-all.kdl": "Zellij layout - htop on all machines",
    ".config/zellij/layouts/tree.kdl": "Zellij layout - file tree sidebar",
    ".config/zellij/layouts/vtab-new-tab.kdl": "Zellij layout - vtab new tab",
    ".config/zellij/scripts/move-menu.sh": "Zellij script - move pane menu",
    ".config/zellij/scripts/pane-menu.sh": "Zellij script - pane management menu",
    ".config/zellij/scripts/resize-menu.sh": "Zellij script - resize pane menu",
    ".config/zellij/scripts/scroll-menu.sh": "Zellij script - scroll mode menu",
    ".config/zellij/scripts/session-menu.sh": "Zellij script - session management menu",
    ".config/zellij/scripts/tab-menu.sh": "Zellij script - tab management menu",
    ".claude/CLAUDE.md": "Claude Code global instructions",
    ".claude/settings.json": "Claude Code settings",
